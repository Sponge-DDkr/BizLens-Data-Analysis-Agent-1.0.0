# BizLens — Environment Variables
# Copy this file to .env and fill in your values

# === Required ===
# DeepSeek API Key (required — get from https://platform.deepseek.com)
DEEPSEEK_API_KEY=sk-your-deepseek-api-key

# === DeepSeek API ===
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat                    # Default model (Insight Agent uses this)
BIZLENS_REASONING_MODEL=deepseek-reasoner       # Reasoning model (Planner/Code/Vis Agents use this)

# === Server ===
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=http://localhost                   # Docker: http://localhost. Dev: http://localhost:5173

# === MCP Knowledge Server ===
# BizLens connects to an independently-deployed MCP Knowledge Server via HTTP.
# In Docker Compose, this is auto-wired as http://mcp-knowledge:8001.
# For local dev, start the MCP server separately:
#   MCP_TRANSPORT=streamable-http python -m mcp_knowledge_agent
# Then set:
# MCP_SERVER_URL=http://localhost:8001

# === Sandbox (optional) ===
# BIZLENS_USE_DOCKER=true                        # Uncomment for production Docker sandbox (default: subprocess)
# SANDBOX_IMAGE=bizlens-sandbox:latest
# SANDBOX_TIMEOUT=30
# SANDBOX_CPU_QUOTA=100000
# SANDBOX_MEM_LIMIT=512m
